#!/bin/bash

# Bootstrapper para Local Python (Alpha Stage)
export PATH="$HOME/.pyenv/shims:$PATH"
export PYENV_SHELL=zsh

# Tenta localizar o Python 3.12.2
PYTHON_EXE=$(which python3.12)
if [ -z "$PYTHON_EXE" ]; then
  PYTHON_EXE="python3"
fi

# Usa um script Python temporário para evitar problemas de escape no shell
SCRIPT_DIR="$(dirname "$0")"
PYTHON_SCRIPT="$SCRIPT_DIR/python/mcp_sidecar.py"

if [ ! -f "$PYTHON_SCRIPT" ]; then
  # Fallback: Se o script não estiver lá (raro no dev), gera um dummy de erro
  echo '{"status": "error", "message": "Sidecar script not found"}'
  exit 1
fi

$PYTHON_EXE "$PYTHON_SCRIPT" "$@"
