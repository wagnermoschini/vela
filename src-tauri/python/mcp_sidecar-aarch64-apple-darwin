#!/bin/bash
# Bootstrap para o sidecar MCP do Vela
# Esse script garante que o Tauri use o Python correto (pyenv) que possui as bibliotecas.

# 1. Tentar carregar o pyenv (comum em Macs de desenvolvedores)
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/shims:$PYENV_ROOT/bin:$PATH"

# 2. Definir o executável Python
# Prioridade: 1. pyenv shim, 2. system python3
if command -v python3 &> /dev/null; then
    PYTHON_EXEC=$(command -v python3)
else
    PYTHON_EXEC="/usr/bin/python3"
fi

# 3. Localizar o script original
CDIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT_PATH="$CDIR/mcp_sidecar.py"

# Se o script .py não existir no bundle (comportamento do Tauri),
# a versão unificada já deve ser este próprio arquivo ou um adjacente.
# Para esta v4, vamos transformar este arquivo no wrapper e manter o .py adjacente
# no ambiente de dev.

exec "$PYTHON_EXEC" "$SCRIPT_PATH" "$@"
